{
  "id": null,
  "uid": "bb-error-analysis",
  "title": "BrainBytes - Error Analysis",
  "tags": [
    "brainbytes",
    "errors",
    "advanced"
  ],
  "timezone": "Asia/Manila",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Error Rate",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(brainbytes_http_requests_total{status=~\"[45]..\", route=~\"$route\", method=~\"$method\"}[$timeRange])) / sum(rate(brainbytes_http_requests_total{route=~\"$route\", method=~\"$method\"}[$timeRange])) * 100",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "orange",
                "value": 5
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {},
      "description": "Multi-threshold stat: green <2%, yellow 2-5%, orange 5-10%, red >10%"
    },
    {
      "id": 2,
      "title": "Errors by Status Code",
      "type": "barchart",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(brainbytes_http_requests_total{status=~\"[45]..\", route=~\"$route\"}[$timeRange]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Total Error Count (window)",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(increase(brainbytes_http_requests_total{status=~\"[45]..\"}[$timeRange]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 200
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "Errors by Route",
      "type": "barchart",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(brainbytes_http_requests_total{status=~\"[45]..\", route=~\"$route\"}[$timeRange]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "Errors by Method",
      "type": "piechart",
      "gridPos": {
        "x": 8,
        "y": 5,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (method) (rate(brainbytes_http_requests_total{status=~\"[45]..\", method=~\"$method\"}[$timeRange]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "{{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 6,
      "title": "4xx vs 5xx Comparison",
      "type": "bargauge",
      "gridPos": {
        "x": 16,
        "y": 5,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(brainbytes_http_requests_total{status=~\"4..\"}[$timeRange]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(brainbytes_http_requests_total{status=~\"5..\"}[$timeRange]))",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 7,
      "title": "Error Rate Heatmap (by time of day)",
      "type": "heatmap",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(brainbytes_http_requests_total{status=~\"[45]..\"}[$timeRange])) by (le)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "calculate": false,
        "color": {
          "mode": "scheme",
          "scheme": "Reds"
        }
      },
      "description": "Shows error concentration patterns across hours of the day"
    },
    {
      "id": 8,
      "title": "Backend Up/Down Timeline",
      "type": "state-timeline",
      "gridPos": {
        "x": 12,
        "y": 11,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"backend\"}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "backend"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {},
      "description": "State timeline showing up/down transitions over time"
    },
    {
      "id": 9,
      "title": "Error Trend (longer period)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(brainbytes_http_requests_total{status=~\"[45]..\"}[1h]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 10,
      "title": "Correlation: Errors vs Request Volume",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 17,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(brainbytes_http_requests_total{status=~\"[45]..\"}[5m]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "errors/s"
        },
        {
          "expr": "sum(rate(brainbytes_http_requests_total[5m]))",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "total requests/s"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 11,
      "title": "Recent Errors (table)",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "topk(20, sum by (route, status, method) (increase(brainbytes_http_requests_total{status=~\"[45]..\"}[$timeRange])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {},
      "description": "Most frequent recent errors grouped by route, status, and method"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "route",
        "type": "query",
        "label": "Route",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(brainbytes_http_requests_total, route)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {}
      },
      {
        "name": "method",
        "type": "query",
        "label": "Method",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(brainbytes_http_requests_total, method)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {}
      },
      {
        "name": "timeRange",
        "type": "interval",
        "label": "Analysis Window",
        "query": "5m,1h,6h,12h,1d,7d",
        "current": {
          "text": "1h",
          "value": "1h"
        },
        "options": [
          {
            "text": "5m",
            "value": "5m"
          },
          {
            "text": "1h",
            "value": "1h"
          },
          {
            "text": "6h",
            "value": "6h"
          },
          {
            "text": "12h",
            "value": "12h"
          },
          {
            "text": "1d",
            "value": "1d"
          },
          {
            "text": "7d",
            "value": "7d"
          }
        ]
      }
    ]
  },
