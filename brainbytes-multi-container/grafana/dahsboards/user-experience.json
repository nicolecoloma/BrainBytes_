{
  "id": null,
  "uid": "bb-tutoring-experience",
  "title": "BrainBytes - Tutoring Experience",
  "tags": [
    "brainbytes",
    "ux"
  ],
  "timezone": "Asia/Manila",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Sessions (concurrent chat requests)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "brainbytes_active_sessions",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "graphMode": "area"
      }
    },
    {
      "id": 2,
      "title": "AI Response Time by Subject (p95)",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 16,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, subject) (rate(brainbytes_ai_response_duration_seconds_bucket{subject=~\"$subject\"}[5m])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "{{subject}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 3,
      "title": "Requests by Subject-Related Route",
      "type": "barchart",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(brainbytes_http_requests_total{route=~\".*message.*|.*chat.*\"}[5m]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 4,
      "title": "AI Response Time Average (all subjects)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "rate(brainbytes_ai_response_duration_seconds_sum[5m]) / rate(brainbytes_ai_response_duration_seconds_count[5m])",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 5,
      "title": "AI Latency Comparison Across Subjects",
      "type": "bargauge",
      "gridPos": {
        "x": 0,
        "y": 11,
        "w": 24,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, subject) (rate(brainbytes_ai_response_duration_seconds_bucket{subject=~\"$subject\"}[5m])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "legendFormat": "{{subject}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "options": {},
      "description": "Which subjects get slower AI responses - useful for prompt/model tuning priorities"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "subject",
        "type": "query",
        "label": "Subject",
        "datasource": {
          "type": "prometheus",
          "uid": "Prometheus"
        },
        "query": "label_values(brainbytes_ai_response_duration_seconds_bucket, subject)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": {}
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "builtIn": 1,
        "hide": true,
        "type": "dashboard"
      }
    ]
  },
  "links": []
}
